{
  "name": "techseovitals.com-hugo",
  "version": "1.0.0",
  "description": "TechSEO Vitals Hugo Site",
  "scripts": {
    "dev": "hugo server --disableFastRender --navigateToChanged",
    "build": "hugo --minify",
    "preview": "hugo server --environment production --disableFastRender",
    "clean": "rm -rf public resources",
    "lint:css": "stylelint \"assets/css/**/*.css\"",
    "lint:css:fix": "stylelint \"assets/css/**/*.css\" --fix",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "hugo",
    "static-site-generator",
    "technical-seo",
    "web-performance"
  ],
  "author": "Martin Stepanek",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "stylelint": "^16.1.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^3.3.6"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
